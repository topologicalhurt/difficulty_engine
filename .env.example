DIFFICULTY_ENGINE_AI_PROVIDER=openai
DIFFICULTY_ENGINE_AI_MODEL=gpt-5-mini
DIFFICULTY_ENGINE_AI_API_KEY=

# Optional custom endpoint for a compatible local or hosted gateway.
DIFFICULTY_ENGINE_AI_ENDPOINT_URL=

# Off by default. Static builds never inline API keys; when enabled, only
# non-secret provider/model/endpoint defaults are embedded.
DIFFICULTY_ENGINE_BUNDLE_ENV=0
